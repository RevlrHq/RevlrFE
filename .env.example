NEXT_PUBLIC_SIGNALR_BATCH_DELAY=500
NEXT_PUBLIC_SIGNALR_MAX_NOTIFICATIONS=100
NEXT_PUBLIC_SIGNALR_PING_INTERVAL=30000
NEXT_PUBLIC_SIGNALR_CONNECTION_TIMEOUT=15000

# Authentication
AUTH_SECRET=
NEXTAUTH_URL=
